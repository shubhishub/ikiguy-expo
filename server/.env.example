# Copy to .env and fill in. The server reads these at startup.

# Google AI Studio key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model id (optional; defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Convex deployment URL, printed by `bunx convex dev` (e.g. https://xxxx.convex.cloud)
CONVEX_URL=

# Google Places API key (enable "Places API (New)") — optional; without it the
# visit-setup screen falls back to manual entry.
GOOGLE_MAPS_API_KEY=

# Google Sign-In: the OAuth client IDs whose tokens this server will accept,
# comma-separated. List every platform client id the app uses (Web, iOS,
# Android), since a token's `aud` is the client id of the platform it came from.
# Create them at https://console.cloud.google.com/apis/credentials
# e.g. GOOGLE_CLIENT_IDS=1234-web.apps.googleusercontent.com,1234-ios.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=

# Port the Fastify server listens on
PORT=3000
