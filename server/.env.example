# Copy to .env and fill in. The server reads these at startup.

# Google AI Studio key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model id (optional; defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Convex deployment URL, printed by `bunx convex dev` (e.g. https://xxxx.convex.cloud)
CONVEX_URL=

# Google Places API key (enable "Places API (New)") — optional; without it the
# visit-setup screen falls back to manual entry.
GOOGLE_MAPS_API_KEY=

# Port the Fastify server listens on
PORT=3000
