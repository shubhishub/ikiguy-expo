# Copy to .env. Expo inlines EXPO_PUBLIC_* vars at build time.

# Base URL of the Fastify server.
# - Simulator/web: http://localhost:3000
# - Physical device: use your computer's LAN IP, e.g. http://192.168.1.20:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Sign-In OAuth client IDs (from Google Cloud Console > Credentials).
# Create one per platform you run. Web is required for `expo start --web`.
# The server must list these same IDs in GOOGLE_CLIENT_IDS (see server/.env.example).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
